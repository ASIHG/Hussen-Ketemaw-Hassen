rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData(request.auth.uid).role in ['CEO', 'Manager'];
    }

    function isCEO() {
      return isSignedIn() && getUserData(request.auth.uid).role == 'CEO';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entities ---

    // 1. User Rules
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'role']) &&
               data.uid == userId &&
               data.email is string &&
               data.role in ['CEO', 'Manager', 'Staff'];
      }

      allow get: if isSignedIn() && (isOwner(userId) || isAdmin()); 
      allow list: if isAdmin();    
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && 
                    isValidUser(incoming()) &&
                    (
                      // Owner can update personal profile but NOT their own role or plan
                      (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'hasCompletedOnboarding', 'selectedClusters']) && incoming().role == existing().role && incoming().plan == existing().plan) ||
                      // Admin (CEO/Manager) can update all fields including roles
                      (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'plan', 'hasCompletedOnboarding', 'selectedClusters', 'role']))
                    );
    }

    // 2. Metrics Rules
    match /metrics/global {
      allow read: if isAdmin();
      allow write: if isCEO();
    }

    // 3. AI Actions & Decisions
    match /actions/{actionId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /ai_decisions/{decisionId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // 4. Notifications (Global Broadcast)
    match /notifications/{notifId} {
      function isValidNotif(data) {
        return data.keys().hasAll(['title', 'message', 'type', 'createdAt']) &&
               data.title.size() < 200 &&
               data.message.size() < 1000;
      }
      allow list, get: if isSignedIn();
      allow create: if isSignedIn(); // Allow users to trigger AI insights which write here
      allow update, delete: if isAdmin();
    }

    // 5. Investments & Clusters
    match /investments/{investmentId} {
      function isValidInvestment(data) {
        return data.keys().hasAll(['title', 'amount', 'category', 'status', 'ownerId']) &&
               data.ownerId == request.auth.uid &&
               data.amount is number &&
               isValidId(investmentId);
      }

      allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidInvestment(incoming());
      allow update: if (isOwner(existing().ownerId) || isAdmin()) && isValidInvestment(incoming());
      allow delete: if isOwner(existing().ownerId) || isCEO();

      match /action_items/{itemId} {
        allow list, get: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
        allow write: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      }
    }

    match /clusters/{clusterId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow write: if isSignedIn() && (incoming().ownerId == request.auth.uid || existing().ownerId == request.auth.uid);
    }

    match /revenue_nodes/{nodeId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow write: if isSignedIn() && (incoming().ownerId == request.auth.uid || existing().ownerId == request.auth.uid);
    }

    // 6. AI Chat & Sessions
    match /chat_sessions/{sessionId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && (incoming().userId == request.auth.uid);
      allow update: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (existing().userId == request.auth.uid || isCEO());
    }

    match /ai_chats/{chatId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && (incoming().userId == request.auth.uid);
      allow update, delete: if isSignedIn() && (existing().userId == request.auth.uid);
    }

    match /archived_ai_chats/{chatId} {
      allow get, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && (incoming().userId == request.auth.uid);
    }

    match /shared_insights/{insightId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (resource.data.fromUserId == request.auth.uid || resource.data.toEmail == request.auth.token.email);
    }
    match /suggested_opportunities/{oppId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isCEO();
    }
  }
}
