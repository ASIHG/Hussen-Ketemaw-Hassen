{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Core user authentication and role data.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["CEO", "Manager", "Staff"] },
        "plan": { "type": "string", "enum": ["free", "pro", "enterprise"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Metric": {
      "title": "SaaS Metric",
      "description": "Live revenue and user growth metrics.",
      "type": "object",
      "properties": {
        "revenue": { "type": "string" },
        "users": { "type": "string" },
        "growth": { "type": "string" },
        "conversion": { "type": "number" },
        "churn": { "type": "number" },
        "roas": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Investment": {
      "title": "Investment Asset",
      "description": "Financial asset tracking data.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["ACTIVE", "PENDING", "COMPLETED"] },
        "roi": { "type": "number" },
        "growthRate": { "type": "number" },
        "riskScore": { "type": "number" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "ActionItem": {
      "title": "Strategic Task",
      "description": "Specific task associated with an investment asset.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "completed": { "type": "boolean" },
        "source": { "type": "string", "enum": ["MANUAL", "AI_CEO", "SYSTEM"] },
        "dueDate": { "type": "string", "format": "date" },
        "investmentId": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "ChatSession": {
      "title": "Strategic Mission Session",
      "description": "Metadata for a group of chat interactions.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "AIChat": {
      "title": "Neural Matrix Interaction",
      "description": "Individual message in a strategic chat.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "sessionId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "ai"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "analysis": { "type": "object" }
      }
    },
    "OpportunitySuggestion": {
      "title": "Neural Discovery Opportunity",
      "description": "AI suggested investment cluster or opportunity.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "sector": { "type": "string" },
        "description": { "type": "string" },
        "potential": { "type": "string" },
        "risk": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "ACCEPTED", "DECLINED"] },
        "suggestedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/investments/{investmentId}": {
      "schema": "Investment",
      "description": "Investment tracking documents."
    },
    "/investments/{investmentId}/action_items/{itemId}": {
      "schema": "ActionItem",
      "description": "Sub-tasks for specific investments."
    },
    "/chat_sessions/{sessionId}": {
      "schema": "ChatSession",
      "description": "Mission session logs."
    },
    "/ai_chats/{chatId}": {
      "schema": "AIChat",
      "description": "Individual neural interaction logs."
    },
    "/metrics/global": {
      "schema": "Metric",
      "description": "Global SaaS platform metrics."
    },
    "/actions/{actionId}": {
      "schema": "Action",
      "description": "Log of autonomous AI actions."
    },
    "/suggested_opportunities/{oppId}": {
      "schema": "OpportunitySuggestion",
      "description": "AI suggested investment nodes."
    }
  }
}
